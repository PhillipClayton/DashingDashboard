# TubularTutor (progress charts)
TUBULAR_TUTOR_URL=https://tubulartutor.onrender.com
TUBULAR_TUTOR_ADMIN_TOKEN=your_admin_bearer_token_here

# Server
PORT=3001
DATA_DIR=./data

# Admin auth (required to protect edit APIs and admin UI)
ADMIN_PASSWORD=your_secure_password_here
ADMIN_SESSION_SECRET=optional_random_string_for_signing_jwts

# Weather (lat/lon for forecast)
WEATHER_LAT=37.7749
WEATHER_LON=-122.4194
